# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never rename it to .env or commit it.
#
# Find these values in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<your-publishable-key>

# NEVER add this to .env.local or any committed file.
# It bypasses RLS and grants full database access.
# If you need it server-side, set it only in Vercel environment variables (server-only, not NEXT_PUBLIC_).
# SUPABASE_SERVICE_ROLE_KEY=<never-commit-this>

# Stripe — server-only, never NEXT_PUBLIC_
# Find secret key in: Stripe Dashboard → Developers → API keys → Secret key (test mode)
# Find webhook secret by running: ~/.local/bin/stripe listen (copy the "webhook signing secret" it prints)
STRIPE_SECRET_KEY=sk_test_<your-test-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-signing-secret>
