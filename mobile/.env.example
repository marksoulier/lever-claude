# Copy this file to .env.local and fill in your values.
# EXPO_PUBLIC_ prefix makes variables available in the app bundle.
# Never put secrets here — this is client-side code running on the device.

EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<your-publishable-key>

# Points the mobile app at the Lever API (change to localhost for local dev)
# Local: http://<your-machine-ip>:3000  (not localhost — device can't reach it)
# Prod:  https://lever-claude.vercel.app
EXPO_PUBLIC_API_URL=https://lever-claude.vercel.app
