# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# mcp-server
/mcp-server/node_modules
/mcp-server/dist

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# playwright cli session state (screenshots, console logs, traces)
.playwright-cli/
# playwright cli project config is committed (.playwright/cli.config.json)

# claude local settings (skills are committed, personal config is not)
.claude/settings.local.json

# supabase agent skills (installed locally via npx, not committed)
.agents/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example is the committed template; real values stay in .env.local
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
